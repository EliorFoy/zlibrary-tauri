{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-json-schema/refs/heads/main/v2/capabilities-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "shell:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DESKTOP/*" }
      ]
    }
  ]
}