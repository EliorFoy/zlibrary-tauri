{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-json-schema/refs/heads/main/v2/tauri-config.schema.json",
  "productName": "Z-Library NoProxy",
  "version": "0.1.0",
  "identifier": "com.zlibrary.noproxy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "features": ["gui"]
  },
  "app": {
    "windows": [
      {
        "title": "Z-Library NoProxy",
        "width": 1100,
        "height": 750,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}